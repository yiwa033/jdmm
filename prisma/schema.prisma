generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DiaryEntry {
  id               String   @id @default(cuid())
  encryptedContent String   // AES-GCM encrypted JSON: {text, mood, weather, temperature, recordedAt}
  encryptedImage   String?  // AES-GCM encrypted base64 image data
  entryDate        String   // YYYY-MM-DD format for calendar lookup (not encrypted)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AppPassword {
  id               String   @id @default(cuid())
  passwordHash     String   // SHA-256 hash of real password
  keySalt          String   // PBKDF2 salt for real key derivation (hex)
  decoyPasswordHash String? // SHA-256 hash of decoy (fake) password
  decoyKeySalt     String?  // PBKDF2 salt for decoy key derivation (hex)
  openCount        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LoginLog {
  id        String   @id @default(cuid())
  ip        String   // IP address
  userAgent String   // Browser/device info
  success   Boolean  // Login success or failed attempt
  createdAt DateTime @default(now())
}

model IntruderPhoto {
  id        String   @id @default(cuid())
  photoData String   // Base64 encoded photo from front camera
  ip        String   // IP at time of capture
  userAgent String   // Device info
  createdAt DateTime @default(now())
}

model PetState {
  id           String   @id @default(cuid())
  petType      String   @default("cat")  // cat, dog, rabbit, hamster
  name         String   @default("小语")
  level        Int      @default(1)
  exp          Int      @default(0)
  happiness    Int      @default(80)      // 0-100
  fullness     Int      @default(80)      // 0-100
  energy       Int      @default(80)      // 0-100
  lastFedAt    DateTime @default(now())
  lastPetAt    DateTime @default(now())
  diaryCount   Int      @default(0)       // total diaries written while owning pet
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
