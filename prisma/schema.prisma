generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DiaryEntry {
  id               String   @id @default(cuid())
  encryptedContent String   // AES-GCM encrypted JSON blob: {text, mood, weather, temperature}
  encryptedImage   String?  // AES-GCM encrypted base64 image data
  entryDate        String   // YYYY-MM-DD format for calendar lookup (not encrypted)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AppPassword {
  id           String   @id @default(cuid())
  passwordHash String   // SHA-256 hash of password (for verification)
  keySalt      String   // PBKDF2 salt for AES key derivation (stored in hex)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
